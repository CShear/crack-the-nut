# Copy this to .env and fill in your values
# cp config/example.env .env

# === General ===
BANKROLL=1000.00
PAPER_TRADE=true

# === Risk ===
MAX_POSITION_SIZE_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.50
MAX_POSITIONS=10
MAX_DAILY_LOSS_PCT=0.05
KILL_SWITCH_PCT=0.20

# === Hyperliquid ===
# HL_WALLET_ADDRESS=0x...
# HL_API_KEY=
# HL_API_SECRET=

# === Polymarket ===
# PM_API_KEY=
# PM_API_SECRET=
# PM_API_PASSPHRASE=

# === Binance ===
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# === DEX (EVM) ===
# RPC_URL=https://mainnet.base.org
# PRIVATE_KEY=

# === Telegram Alerts (optional) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === AI / Agents (optional) ===
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
